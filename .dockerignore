# ============================================
# Aggressive Docker Build Context Exclusions
# For SIIMUT Application Only
# ============================================

# ============================================
# Version Control & Git
# ============================================
.git
.gitignore
.gitattributes
.gitmodules

# ============================================
# Development Files & Documentation
# ============================================
README*.md
*.md
DEPLOYMENT-GUIDE.md
CHANGE_LOG.md
FIX_IMPLEMENTATION_COMPLETE.md
LOGIN_CONDITIONAL_SETUP.md
VERIFICATION_REPORT.md
IMPLEMENTATION-SUMMARY.md
TESTING-CHECKLIST.md
QUICK_REFERENCE.txt
API-TESTING-RESULTS.md
TESTING-REPORT-*.md
USER-SYNC-DEBUG-GUIDE.md
CONFIGURATION_CHANGES_SUMMARY.md

# ============================================
# CI/CD & Scripts (not needed in image)
# ============================================
prepare-*.sh
diagnose-*.sh
install-docker.sh
entrypoint-livewire-publish.sh
.github/
.gitlab-ci.yml
.circleci/

# ============================================
# Build & Package Managers
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
dist/
build/

# ============================================
# Unnecessary App Directories (Multi-repo)
# Only SIIMUT needed, exclude others
# ============================================
site/ikp/
site/iam-server/

# ============================================
# Testing (not needed in production)
# ============================================
tests/
phpunit.xml
*.test.js
*.spec.js
test-*.php
analyze-debug-logs.php
debug-*.php
verify-*.sh

# ============================================
# Documentation & Guides
# ============================================
docs/
ansible/

# ============================================
# Environment & Secrets
# ============================================
.env*
!.env.example
.env.local

# ============================================
# IDE & Editors
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.vimrc
.editorconfig

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
.swp
.swo
*~

# ============================================
# Docker Files (already in use)
# ============================================
docker-compose*.yml
Dockerfile*
.dockerignore
entrypoint*.sh

# ============================================
# Temporary & Cache
# ============================================
.cache/
/tmp
/temp
*.log
*.swp
*.bak

# ============================================
# Version Control (tracked separately)
# ============================================
VERSION
.env.docker
.env.example.new

# ============================================
# Miscellaneous
# ============================================
.editorconfig
.gitkeep
cookies.txt

# Temporary files  
**/tmp/
**/temp/

# Don't ignore the site directory - this is our source code
!site/
!site/**